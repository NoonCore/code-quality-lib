{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/index.ts", "src/app/**/*.tsx", "src/pages/**/*.tsx"],
  "project": ["src/**/*.{ts,tsx,js,jsx}"],
  "ignore": ["**/*.test.{ts,tsx}", "**/*.spec.{ts,tsx}", "**/__tests__/**"],
  "ignoreDependencies": [],
  "ignoreExportsUsedInFile": true
}
