{
  "entry": ["src/**/*.{js,jsx,ts,tsx}"],
  "project": ["src/**/*.{js,jsx,ts,tsx}"],
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "*.config.js",
    "*.config.ts",
    "test/**",
    "**/*.test.*",
    "**/*.spec.*",
    "examples/**",
    ".code-quality/eslint.config.mjs",
    ".code-quality/tsconfig.json",
    ".code-quality/prettier*",
    ".code-quality/config.json",
    "**/*.d.ts",
    ".next/**",
    "out/**"
  ],
  "ignoreBinaries": ["code-quality"],
  "ignoreDependencies": [
    "eslint-plugin-*",
    "@typescript-eslint/*",
    "@eslint/js",
    "prettier",
    "@types/*",
    "typescript",
    "knip",
    "snyk",
    "dotenv",
    "@next/eslint-plugin-next"
  ]
}
