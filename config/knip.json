{
  "entry": ["index.js"],
  "project": ["*.js"],
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "*.config.js",
    "*.config.ts",
    "test/**",
    "**/*.test.*",
    "**/*.spec.*",
    "examples/**",
    ".code-quality/**",
    "**/*.d.ts"
  ],
  "ignoreBinaries": ["code-quality"],
  "ignoreDependencies": [
    "eslint-plugin-*",
    "@typescript-eslint/*",
    "prettier",
    "@types/*",
    "typescript",
    "knip",
    "snyk",
    "dotenv"
  ]
}
